# ─────────────────────────────────────────────────────────────────────────────
# Aguaa Frontend — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   Development: copy this file to .env and fill in values
#   Production:  set these in Vercel → Project Settings → Environment Variables
#
# NEVER commit the actual .env file — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API URL ───────────────────────────────────────────────────────────
# Development: http://localhost:5006/api  (must match PORT in backend/.env)
# Production:  https://your-render-app.onrender.com/api
VITE_API_URL=http://localhost:5006/api

# ── Google OAuth Client ID ────────────────────────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized JS origins must include your frontend URL (http://localhost:5173 for dev)
# Authorized redirect URIs must include your frontend URL too
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# ── Error Monitoring — Sentry ─────────────────────────────────────────────────
# Optional. When set, all logger.error() calls are routed to Sentry automatically.
# Activation steps:
#   1. Create a project at https://sentry.io (free tier available)
#   2. npm install @sentry/react
#   3. Copy the DSN from Sentry → Project Settings → Client Keys
#   4. Set this variable in Vercel environment variables (Production env only)
# Leave empty to disable Sentry (app functions normally without it).
VITE_SENTRY_DSN=

# ── App Identity (Optional overrides) ────────────────────────────────────────
# These have sensible defaults — only set if you need to override.
# VITE_APP_NAME=Aguaa
# VITE_APP_URL=https://aguaa.in
# VITE_APP_ENV=production

# ── Feature Flags ─────────────────────────────────────────────────────────────
# AI-assisted biodata suggestions (powered by backend AI route)
# VITE_FEATURE_AI_ASSIST=true
