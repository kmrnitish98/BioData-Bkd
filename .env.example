# Backend Environment Variables Example
# Copy this file to .env and fill in the values

# Server Configuration
NODE_ENV=development
PORT=5006

# MongoDB Connection String (Replace with your actual URI)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/biodata

# JWT Configuration (Generate a strong secret key for production)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Frontend URL (For CORS allowlist)
CLIENT_URL=http://localhost:5173

# Cloudinary Configuration (For photo uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
